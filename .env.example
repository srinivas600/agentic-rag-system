# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIM=1536

# Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=rag-documents
PINECONE_ENVIRONMENT=us-east-1

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ragagent
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/ragagent

# Redis
REDIS_URL=redis://localhost:6379/0

# MCP Server
MCP_SERVER_HOST=0.0.0.0
MCP_SERVER_PORT=8001

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true

# Agent
AGENT_MAX_ITERATIONS=6
AGENT_TEMPERATURE=0.1

# Re-ranker
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=5

# Chunking
CHUNK_SIZE_PARENT=512
CHUNK_SIZE_CHILD=128
CHUNK_OVERLAP=20

# Observability
LANGSMITH_API_KEY=your-langsmith-api-key
LANGSMITH_PROJECT=rag-agent
LANGSMITH_TRACING=true

# Embedding Cache TTL (seconds)
EMBEDDING_CACHE_TTL=86400
